# Copy this file to ".env" for local development (never commit the real .env).
# On Render, do NOT upload a .env file — instead set these under
# Dashboard → your service → Environment.

# Your MongoDB Atlas connection string. In Atlas: Database → Connect →
# "Drivers" → copy the connection string, then replace <username>/<password>
# with your database user credentials and <dbname> is optional (set below).
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

# Optional — database name to use inside your Atlas cluster. Defaults to
# "library_management" if not set.
MONGODB_DB_NAME=library_management

# Optional — port the Express server listens on locally. Render sets its own
# PORT automatically in production, so this is only used for local dev.
PORT=4000
